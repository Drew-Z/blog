---
import { withBase } from '../utils/site';

interface Props {
  title: string;
  embedUrl?: string;
}

const { title, embedUrl } = Astro.props;
---

<section class="game-embed card">
  <div class="section-heading">
    <h2>在线试玩</h2>
    {embedUrl && (
      <a href={withBase(embedUrl)} target="_blank" rel="noopener noreferrer">新标签打开</a>
    )}
  </div>
  {embedUrl ? (
    <>
      <p class="content-meta">试玩资源由独立静态存储提供。首次进入需要下载 Godot Web 运行时和项目资源，进度较慢时更推荐用新标签页打开等待加载完成。</p>
      <iframe
        src={withBase(embedUrl)}
        title={`${title} 在线试玩`}
        loading="lazy"
        allow="autoplay; fullscreen; gamepad"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </>
  ) : (
    <p>当前还没有可以直接嵌入的 Web 版本。</p>
  )}
</section>
