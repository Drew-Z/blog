---
import { withBase } from '../utils/site';
import { devlogProjectLabels, formatDate } from '../utils/site-meta';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  project: string;
  featured?: boolean;
}

const {
  href,
  title,
  description,
  pubDate,
  tags = [],
  project,
  featured = false
} = Astro.props;
---

<article class="card article-card article-card--rich">
  <div class="card-media card-media-placeholder card-media-placeholder--log">
    <p class="eyebrow">Devlog</p>
    <strong>{devlogProjectLabels[project] ?? project}</strong>
  </div>
  <div class="card-body">
    <div class="meta-row meta-row--top">
      <p class="eyebrow">开发日志</p>
      {featured ? <span class="status-pill status-pill--active">推荐</span> : null}
    </div>
    <h3><a href={withBase(href)}>{title}</a></h3>
    <p>{description}</p>
    <div class="meta-row">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <div class="tag-list">
        {tags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>
    <a class="inline-link" href={withBase(href)}>查看阶段记录</a>
  </div>
</article>
