---
import { withBase } from '../utils/site';
import { gameStatusLabels } from '../utils/site-meta';

interface Props {
  slug?: string;
  href: string;
  title: string;
  summary: string;
  description: string;
  status: string;
  role?: string;
  platforms?: string[];
  playableWeb?: boolean;
  thumbnail?: string;
  featured?: boolean;
  screenshotCount?: number;
  engine?: string;
  currentPhase?: string;
  playUrl?: string;
}

const {
  slug,
  href,
  title,
  summary,
  description,
  status,
  role,
  platforms = [],
  playableWeb = false,
  thumbnail,
  featured = false,
  screenshotCount = 0,
  engine,
  currentPhase,
  playUrl
} = Astro.props;

const projectAccents: Record<string, { accent: string; accent2: string; rgb: string }> = {
  'first-tetris': { accent: '#0078d4', accent2: '#00a99d', rgb: '0, 120, 212' },
  'next-spacewar': { accent: '#0b7bd3', accent2: '#4aa3ff', rgb: '11, 123, 211' },
  intespace: { accent: '#00a99d', accent2: '#7cddc9', rgb: '0, 169, 157' },
  raiden: { accent: '#ff7a59', accent2: '#f4b23f', rgb: '255, 122, 89' },
  'space-war': { accent: '#21a65b', accent2: '#9fd36a', rgb: '33, 166, 91' },
  'spacewar-ii': { accent: '#6f7cff', accent2: '#ffce5c', rgb: '111, 124, 255' }
};
const accent = slug ? projectAccents[slug] : undefined;
const accentStyle = accent
  ? `--project-accent: ${accent.accent}; --project-accent-2: ${accent.accent2}; --project-rgb: ${accent.rgb};`
  : undefined;
---

<article class:list={['card', 'game-card', 'game-card--rich', slug && `game-card--${slug}`]} style={accentStyle}>
  <a class="card-media" href={withBase(href)} aria-label={`查看项目详情：${title}`}>
    {thumbnail ? (
      <>
        <img src={withBase(thumbnail)} alt={title} loading="lazy" decoding="async" />
        <div class="card-media-overlay card-media-overlay--game">
          <div class="tag-list">
            {featured ? <span class="status-pill status-pill--active">重点项目</span> : null}
            <span class:list={["status-pill", playableWeb && 'status-pill--active']}>{playableWeb ? '可在线试玩' : '案例展示中'}</span>
          </div>
          <div class="card-media-meta">
            <strong>{title}</strong>
            <span>{engine ?? '游戏项目'} / {screenshotCount} 张画面</span>
          </div>
        </div>
      </>
    ) : (
      <div class="card-media-placeholder card-media-placeholder--game">
        <p class="eyebrow">Game</p>
        <strong>{title}</strong>
      </div>
    )}
  </a>
  <div class="card-body">
    <div class="game-card-top">
      <p class="eyebrow">Project Case</p>
      <span class="status-pill">{gameStatusLabels[status] ?? status}</span>
    </div>
    <h3><a href={withBase(href)}>{title}</a></h3>
    <p>{summary}</p>

    <div class="game-card-signals">
      <span class="badge">{engine ?? 'Godot 项目'}</span>
      <span class="badge">{screenshotCount} 张关键画面</span>
      <span class="badge">{playableWeb ? 'Web 可试玩' : '案例阅读'}</span>
    </div>

    <div class="game-card-detail-list">
      <span><strong>验证</strong>{description}</span>
      <span><strong>职责</strong>{role ?? '待补充'}</span>
      <span><strong>阶段</strong>{currentPhase ?? gameStatusLabels[status] ?? status}</span>
      <span><strong>平台</strong>{platforms.join(' / ') || '待补充'}</span>
    </div>

    <div class="game-card-foot">
      <span class="game-card-track">{playableWeb ? '可直接试玩，也适合当作品集入口' : '当前以案例和截图展示为主'}</span>
      <div class="card-actions">
        {playableWeb && playUrl ? (
          <a class="button button--small" href={withBase(playUrl)} target="_blank" rel="noopener noreferrer">立即试玩</a>
        ) : null}
        <a class="inline-link" href={withBase(href)}>查看项目详情</a>
      </div>
    </div>
  </div>
</article>
