---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentToc from '../../components/ContentToc.astro';
import GameEmbed from '../../components/GameEmbed.astro';
import { toSiteUrl, withBase } from '../../utils/site';
import { estimateReadingTime, formatDate, gameStatusLabels } from '../../utils/site-meta';
import { getAuthorSchema, getImageUrl } from '../../utils/schema';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game }
  }));
}

const { game } = Astro.props;
const { Content, headings } = await render(game);
const allGames = await getCollection('games');
const relatedGames = allGames
  .filter((item) => item.id !== game.id)
  .map((item) => ({
    item,
    score: item.data.tags.filter((tag) => game.data.tags.includes(tag)).length
  }))
  .sort((a, b) => b.score - a.score || b.item.data.pubDate.valueOf() - a.item.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ item }) => item);
const projectPersonas: Record<string, { kicker: string; identity: string; tempo: string; proof: string; accent: string; accent2: string; rgb: string }> = {
  'first-tetris': {
    kicker: 'Rogue Tetris Lab',
    identity: '经典方块 + Rogue 实验',
    tempo: '中速思考 / 多端验证',
    proof: '触屏桥接与固定尺寸回归',
    accent: '#0078d4',
    accent2: '#00a99d',
    rgb: '0, 120, 212'
  },
  'next-spacewar': {
    kicker: 'Showcase Shooter',
    identity: '单关空战展示版',
    tempo: '短局战斗 / 外层流程',
    proof: '菜单、帮助、结果页完整串联',
    accent: '#0b7bd3',
    accent2: '#4aa3ff',
    rgb: '11, 123, 211'
  },
  intespace: {
    kicker: 'Mobile Roguelite',
    identity: '竖屏自动射击 Roguelite',
    tempo: '手机优先 / 完整 session',
    proof: '武器树冻结与局外成长接入',
    accent: '#00a99d',
    accent2: '#7cddc9',
    rgb: '0, 169, 157'
  },
  raiden: {
    kicker: 'Arcade RC Build',
    identity: '纵版街机射击 Demo',
    tempo: '高压短局 / 双关章节',
    proof: 'RC-0.4、Boss、Outro 与发布包',
    accent: '#ff7a59',
    accent2: '#f4b23f',
    rgb: '255, 122, 89'
  },
  'space-war': {
    kicker: 'Retro Release',
    identity: 'Nokia 横向卷轴复刻',
    tempo: '短局高压 / 完整发布',
    proof: '5 个 Sector、最终 Boss 与 Release',
    accent: '#21a65b',
    accent2: '#9fd36a',
    rgb: '33, 166, 91'
  },
  'spacewar-ii': {
    kicker: 'Mobile Sequel Lab',
    identity: '纵向移动射击续作原型',
    tempo: '短局清屏 / 升级拾取',
    proof: '菜单、战斗、HUD、结算与 Web 导出接线',
    accent: '#6f7cff',
    accent2: '#ffce5c',
    rgb: '111, 124, 255'
  }
};
const fallbackPersona = {
  kicker: 'Game Case',
  identity: game.data.tags.slice(0, 2).join(' / ') || '游戏项目',
  tempo: game.data.currentPhase ?? game.data.summary,
  proof: game.data.playableWeb ? 'Web 试玩已接通' : '案例资料已整理',
  accent: '#0078d4',
  accent2: '#00a99d',
  rgb: '0, 120, 212'
};
const projectPersona = projectPersonas[game.id] ?? fallbackPersona;
const projectNavItems = [...allGames]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((item) => ({
    item,
    persona: projectPersonas[item.id] ?? {
      ...fallbackPersona,
      identity: item.data.tags.slice(0, 2).join(' / ') || item.data.summary
    }
  }));
const hasLinks = game.data.downloadLinks.length > 0 || Boolean(game.data.externalPage);
const repoFileBase =
  game.data.repoUrl && game.data.currentBranch
    ? `${game.data.repoUrl.replace(/\/$/, '')}/blob/${game.data.currentBranch}`
    : undefined;
const keyDocsWithLinks = game.data.keyDocs.map((doc) => ({
  ...doc,
  href: repoFileBase ? `${repoFileBase}/${doc.path.replace(/^\/+/, '')}` : undefined
}));
const primaryDownload = game.data.downloadLinks.find((link) => !link.url.includes('play.playlab.eu.cc'));
const primaryDoc = keyDocsWithLinks.find((doc) => Boolean(doc.href));
const hasSyncDetails =
  Boolean(game.data.currentPhase) ||
  Boolean(game.data.currentBranch) ||
  Boolean(game.data.workspacePath) ||
  Boolean(game.data.syncRepoPath) ||
  Boolean(game.data.syncNote) ||
  game.data.progressSummary.length > 0 ||
  game.data.keyDocs.length > 0 ||
  game.data.directoryMap.length > 0;
const evidenceItems = [
  game.data.workspacePath
    ? { label: '本地项目', value: game.data.workspacePath }
    : undefined,
  game.data.syncRepoPath
    ? { label: '同步仓库', value: game.data.syncRepoPath }
    : undefined,
  game.data.currentBranch
    ? { label: '当前分支', value: game.data.currentBranch }
    : undefined,
  game.data.currentPhase
    ? { label: '当前阶段', value: game.data.currentPhase }
    : undefined
].filter((item): item is { label: string; value: string } => Boolean(item));
const heroStats = [
  { label: '阶段', value: gameStatusLabels[game.data.status] ?? game.data.status },
  { label: '引擎', value: game.data.engine },
  { label: '平台', value: game.data.platforms.slice(0, 2).join(' / ') || '待补充' },
  { label: '体验', value: game.data.playableWeb ? '可在线试玩' : hasLinks ? '可下载体验' : '案例展示' }
];
const playtestStats = [
  { label: '录制来源', value: '本地 Godot 实机' },
  { label: '片段长度', value: '8 秒 / 1080p' },
  { label: '默认语言', value: '中文流程' },
  { label: '展示重点', value: game.data.playableWeb ? '真实局内试玩' : '当前完成度' }
];
const playtestCopyByProject: Record<string, { title: string; summary: string }> = {
  'first-tetris': {
    title: '直接看局内节奏',
    summary: '这段视频聚焦棋盘、HUD 和触屏按钮的真实同屏状态，用来判断经典模式、Rogue 信息和移动端输入是否能同时保持可读。'
  }
};
const playtestCopy = playtestCopyByProject[game.id] ?? {
  title: '先看节奏，再进试玩',
  summary: '这段视频不是静态封面，而是直接进入局内后的自动试玩片段，适合快速判断操作反馈、HUD 信息和战斗密度。'
};
const readingTime = estimateReadingTime(game.body);
const gameUrl = toSiteUrl(`/games/${game.id}`, Astro.site);
const authorSchema = getAuthorSchema(Astro.site);
const gameSameAs = [game.data.externalPage, game.data.repoUrl].filter((url): url is string => Boolean(url));
const gameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  '@id': `${gameUrl}#game`,
  name: game.data.title,
  description: game.data.summary,
  image: getImageUrl(game.data.thumbnail, Astro.site),
  url: gameUrl,
  datePublished: game.data.pubDate.toISOString(),
  dateModified: (game.data.updatedDate ?? game.data.pubDate).toISOString(),
  author: authorSchema,
  creator: authorSchema,
  gamePlatform: game.data.platforms,
  keywords: game.data.tags,
  genre: game.data.tags,
  sameAs: gameSameAs.length > 0 ? gameSameAs : undefined,
  inLanguage: 'zh-CN'
};
---

<BaseLayout
  title={`${game.data.title} | 项目案例`}
  description={game.data.summary}
  image={game.data.thumbnail}
  type="article"
  structuredData={gameSchema}
>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '作品', href: '/games' }, { label: game.data.title }]} />
  <article class="content-layout">
    <div class="content-main">
      <header
        class={`content-header card content-header--game project-hero project-hero--${game.id}`}
        style={`--project-accent: ${projectPersona.accent}; --project-accent-2: ${projectPersona.accent2}; --project-rgb: ${projectPersona.rgb};`}
      >
        <div class="content-header-copy">
          <p class="eyebrow">{projectPersona.kicker}</p>
          <h1>{game.data.title}</h1>
          <p>{game.data.summary}</p>
          <div class="tag-list">
            {game.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
          <div class="project-persona-strip" aria-label="项目定位">
            <span><strong>定位</strong>{projectPersona.identity}</span>
            <span><strong>节奏</strong>{projectPersona.tempo}</span>
            <span><strong>证据</strong>{projectPersona.proof}</span>
          </div>
          <div class="project-hero-stats" aria-label="项目关键状态">
            {heroStats.map((item) => (
              <div>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))}
          </div>
          <div class="project-hero-actions">
            {game.data.playableWeb && game.data.embedUrl ? (
              <a class="button" href="#play">进入在线试玩</a>
            ) : null}
            {game.data.playtestVideo ? (
              <a class="button--ghost" href="#playtest">查看试玩视频</a>
            ) : null}
            {game.data.repoUrl ? (
              <a class="button--ghost" href={game.data.repoUrl} target="_blank" rel="noopener noreferrer">查看仓库</a>
            ) : null}
          </div>
        </div>

        {game.data.thumbnail ? (
          <div class="content-header-visual project-hero-visual">
            <img src={withBase(game.data.thumbnail)} alt={game.data.title} loading="eager" decoding="async" fetchpriority="high" />
            <div class="project-hero-visual-overlay" aria-hidden="true">
              <span>{projectPersona.identity}</span>
              <strong>{game.data.currentPhase ?? projectPersona.proof}</strong>
            </div>
          </div>
        ) : null}
      </header>

      <nav class="card project-switcher" aria-label="六个项目导航">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Project Lineup</p>
            <h2>六个项目横向对照</h2>
            <p class="content-meta">每个项目保留不同定位：经典、展示版、Roguelite、街机 Demo、复刻发布和移动射击续作原型。</p>
          </div>
        </div>
        <div class="project-switcher-grid">
          {projectNavItems.map(({ item, persona }) => (
            <a
              class:list={['project-switcher-card', item.id === game.id && 'is-active']}
              href={withBase(`/games/${item.id}`)}
              style={`--project-accent: ${persona.accent}; --project-accent-2: ${persona.accent2}; --project-rgb: ${persona.rgb};`}
            >
              {item.data.thumbnail ? (
                <img src={withBase(item.data.thumbnail)} alt="" loading="lazy" decoding="async" />
              ) : null}
              <span>{persona.kicker}</span>
              <strong>{item.data.title}</strong>
              <small>{persona.identity}</small>
            </a>
          ))}
        </div>
      </nav>

      {game.data.playtestVideo ? (
        <section id="playtest" class="card project-playtest-panel">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Playtest Video</p>
              <h2>试玩视频</h2>
              <p class="content-meta">基于本地 Godot 运行录制生成，用来快速观察项目节奏、界面状态和当前完成度。</p>
            </div>
          </div>
          <div class="project-playtest-shell">
            <div class="project-playtest-copy">
              <span class="playtest-status-dot">实机录制</span>
              <h3>{playtestCopy.title}</h3>
              <p>{playtestCopy.summary}</p>
              <div class="project-playtest-stats">
                {playtestStats.map((item) => (
                  <div>
                    <span>{item.label}</span>
                    <strong>{item.value}</strong>
                  </div>
                ))}
              </div>
            </div>
            <div class="project-playtest-media">
              <video
                controls
                playsinline
                preload="metadata"
                poster={game.data.playtestPoster ? withBase(game.data.playtestPoster) : undefined}
              >
                <source src={withBase(game.data.playtestVideo)} type="video/mp4" />
              </video>
            </div>
          </div>
        </section>
      ) : null}

      {game.data.playableWeb ? (
        <GameEmbed title={game.data.title} embedUrl={game.data.embedUrl} />
      ) : (
        <section class="card game-fallback-note">
          <div class="section-heading">
            <h2>当前展示方式</h2>
          </div>
          <p>这个项目当前以案例页和截图为主。后续如果补到稳定的 Web 导出或下载包，再把体验入口挂进来。</p>
        </section>
      )}

      <section class="card game-highlight-band">
        <div class="mini-panel">
          <p class="eyebrow">项目目标</p>
          <p>{game.data.challenge ?? game.data.description}</p>
        </div>
        <div class="mini-panel">
          <p class="eyebrow">核心机制</p>
          <p>{game.data.mechanic ?? game.data.summary}</p>
        </div>
        <div class="mini-panel">
          <p class="eyebrow">我的职责</p>
          <p>{game.data.role ?? '待补充'}</p>
        </div>
        <div class="mini-panel">
          <p class="eyebrow">当前结论</p>
          <p>{game.data.outcome ?? '项目仍在迭代中，阶段结论会随版本更新继续补齐。'}</p>
        </div>
      </section>

      <section class="card project-action-panel">
        <div class="section-heading">
          <div>
            <h2>快速进入</h2>
            <p class="content-meta">新标签试玩、下载、仓库和文档集中放在这里，方便直接验证项目状态。</p>
          </div>
        </div>
        <div class="project-action-grid">
          {game.data.playableWeb && game.data.embedUrl ? (
            <a class="project-action-card project-action-card--primary" href={withBase(game.data.embedUrl)} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Play</span>
              <strong>新标签试玩</strong>
              <span>独立打开当前 Web build</span>
            </a>
          ) : null}
          {primaryDownload ? (
            <a class="project-action-card" href={withBase(primaryDownload.url)} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Download</span>
              <strong>{primaryDownload.label}</strong>
              <span>从 GitHub 获取可下载版本</span>
            </a>
          ) : null}
          {game.data.repoUrl ? (
            <a class="project-action-card" href={game.data.repoUrl} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">GitHub</span>
              <strong>查看代码仓库</strong>
              <span>查看源码、提交和项目结构</span>
            </a>
          ) : null}
          {primaryDoc?.href ? (
            <a class="project-action-card" href={primaryDoc.href} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Docs</span>
              <strong>{primaryDoc.label}</strong>
              <span>{primaryDoc.path}</span>
            </a>
          ) : null}
        </div>
      </section>

      {hasSyncDetails && (
        <section class="card project-evidence-panel">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Source-backed case</p>
              <h2>项目证据</h2>
              <p class="content-meta">把真实开发目录、同步状态和关键文档放到案例页前段，便于快速判断项目可信度。</p>
            </div>
          </div>

          {evidenceItems.length > 0 && (
            <div class="project-evidence-grid">
              {evidenceItems.map((item) => (
                <div class="project-evidence-item">
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                </div>
              ))}
            </div>
          )}

          {game.data.progressSummary.length > 0 && (
            <div class="project-progress-strip">
              {game.data.progressSummary.slice(0, 4).map((item) => <span>{item}</span>)}
            </div>
          )}

          {game.data.keyDocs.length > 0 && (
            <div class="project-doc-strip">
              {keyDocsWithLinks.slice(0, 4).map((doc) => (
                doc.href ? (
                  <a href={doc.href} target="_blank" rel="noopener noreferrer">
                    <span>{doc.label}</span>
                    <strong>{doc.path}</strong>
                  </a>
                ) : (
                  <div>
                    <span>{doc.label}</span>
                    <strong>{doc.path}</strong>
                  </div>
                )
              ))}
              </div>
          )}
        </section>
      )}

      {game.data.milestones.length > 0 && (
        <section class="card">
          <div class="section-heading">
            <div>
              <h2>阶段里程碑</h2>
              <p class="content-meta">按版本节点呈现项目的成形过程。</p>
            </div>
          </div>
          <div class="milestone-list">
            {game.data.milestones.map((milestone) => (
              <article class="milestone-item">
                <p class="eyebrow">{formatDate(milestone.date)}</p>
                <h3>{milestone.title}</h3>
                <p>{milestone.summary}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="prose-block prose-block--game">
        <Content />
      </section>

      {game.data.screenshots.length > 0 && (
        <section class="card">
          <div class="section-heading">
            <div>
              <h2>关键画面</h2>
              <p class="content-meta">展示对理解项目最有帮助的界面和运行画面。</p>
            </div>
          </div>
          <div class="screenshot-grid screenshot-grid--rich">
            {game.data.screenshots.map((shot, index) => (
              <figure class="screenshot-card screenshot-card--image">
                <img src={withBase(shot.src)} alt={`${game.data.title} 截图 ${index + 1}`} loading="lazy" decoding="async" />
                <figcaption>
                  <p class="eyebrow">Scene {index + 1}</p>
                  <strong>{shot.title}</strong>
                  {shot.note ? <span>{shot.note}</span> : null}
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      )}

      {relatedGames.length > 0 && (
        <section class="card">
          <div class="section-heading">
            <div>
              <h2>更多项目</h2>
              <p class="content-meta">同类标签下的其他项目。</p>
            </div>
          </div>
          <div class="link-list">
            {relatedGames.map((item) => (
              <a href={withBase(`/games/${item.id}`)}>{item.data.title}</a>
            ))}
          </div>
        </section>
      )}
    </div>

    <aside class="content-sidebar card">
      <section>
        <div class="section-heading">
          <h2>项目速览</h2>
        </div>
        <div class="meta-grid">
          <div class="mini-panel">
            <p class="eyebrow">首次记录</p>
            <p>{formatDate(game.data.pubDate)}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">最近更新</p>
            <p>{game.data.updatedDate ? formatDate(game.data.updatedDate) : formatDate(game.data.pubDate)}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">阅读时长</p>
            <p>{readingTime}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">阶段</p>
            <p>{gameStatusLabels[game.data.status] ?? game.data.status}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">引擎</p>
            <p>{game.data.engine}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">团队规模</p>
            <p>{game.data.teamSize ?? '单人'}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">平台</p>
            <p>{game.data.platforms.join(' / ') || '待补充'}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">关键画面</p>
            <p>{game.data.screenshots.length} 张项目截图</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">体验方式</p>
            <p>{game.data.playableWeb ? '可在线试玩' : hasLinks ? '可通过外链或下载体验' : '案例页展示'}</p>
          </div>
          {game.data.currentPhase && (
            <div class="mini-panel">
              <p class="eyebrow">当前阶段</p>
              <p>{game.data.currentPhase}</p>
            </div>
          )}
          {game.data.currentBranch && (
            <div class="mini-panel">
              <p class="eyebrow">同步分支</p>
              <p>{game.data.currentBranch}</p>
            </div>
          )}
        </div>
      </section>

      <ContentToc headings={headings} />

      {hasSyncDetails && (
        <section>
          <div class="section-heading">
            <h2>开发同步</h2>
          </div>
          {game.data.workspacePath && (
            <div class="mini-panel">
              <p class="eyebrow">开发目录</p>
              <p><code>{game.data.workspacePath}</code></p>
            </div>
          )}
          {game.data.syncRepoPath && game.data.syncRepoPath !== game.data.workspacePath && (
            <div class="mini-panel">
              <p class="eyebrow">同步仓库</p>
              <p><code>{game.data.syncRepoPath}</code></p>
            </div>
          )}
          {game.data.syncNote && (
            <div class="mini-panel">
              <p class="eyebrow">同步说明</p>
              <p>{game.data.syncNote}</p>
            </div>
          )}
          {game.data.progressSummary.length > 0 && (
            <ul class="timeline-list">
              {game.data.progressSummary.map((item) => <li>{item}</li>)}
            </ul>
          )}
          {game.data.directoryMap.length > 0 && (
            <div class="meta-grid">
              {game.data.directoryMap.map((item) => (
                <div class="mini-panel">
                  <p class="eyebrow">{item.label}</p>
                  <p>{item.summary}</p>
                </div>
              ))}
            </div>
          )}
          {game.data.keyDocs.length > 0 && (
            <div class="link-list link-list--stacked">
              {keyDocsWithLinks.map((doc) => (
                <div class="mini-panel">
                  <p class="eyebrow">{doc.label}</p>
                  {doc.href ? (
                    <a href={doc.href} target="_blank" rel="noopener noreferrer">
                      <strong>打开仓库文档</strong>
                      <span><code>{doc.path}</code></span>
                    </a>
                  ) : (
                    <p><code>{doc.path}</code></p>
                  )}
                </div>
              ))}
            </div>
          )}
        </section>
      )}

      {game.data.contribution.length > 0 && (
        <section>
          <div class="section-heading">
            <h2>主要工作</h2>
          </div>
          <ul class="timeline-list">
            {game.data.contribution.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      {game.data.nextStep.length > 0 && (
        <section>
          <div class="section-heading">
            <h2>下一步</h2>
          </div>
          <ul class="timeline-list">
            {game.data.nextStep.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      {hasLinks && (
        <section>
          <div class="section-heading">
            <h2>体验入口</h2>
          </div>
          {game.data.downloadLinks.length > 0 && (
            <div class="download-list download-list--stacked">
              {game.data.downloadLinks.map((link) => (
                <a href={withBase(link.url)} target="_blank" rel="noopener noreferrer">{link.label}</a>
              ))}
            </div>
          )}
          {game.data.externalPage && (
            <div class="link-list link-list--stacked">
              <a href={game.data.externalPage} target="_blank" rel="noopener noreferrer">查看外部项目页</a>
            </div>
          )}
          {!game.data.externalPage && game.data.repoUrl && (
            <div class="link-list link-list--stacked">
              <a href={game.data.repoUrl} target="_blank" rel="noopener noreferrer">查看代码仓库</a>
            </div>
          )}
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
