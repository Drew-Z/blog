---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveFilter from '../../components/ArchiveFilter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GameCard from '../../components/GameCard.astro';
import { withBase } from '../../utils/site';
import { sortEditorialEntries } from '../../utils/entries';
import { gameStatusLabels, siteMeta } from '../../utils/site-meta';

const games = sortEditorialEntries(await getCollection('games'));
const featuredCount = games.filter((game) => game.data.featured).length;
const playableCount = games.filter((game) => game.data.playableWeb || game.data.status === 'playable').length;
const ongoingCount = games.filter((game) => game.data.status === 'ongoing').length;
const entryGame = games[0];
const galleryShots = games
  .flatMap((game) =>
    game.data.screenshots.slice(0, 2).map((shot, index) => ({
      href: `/games/${game.id}`,
      title: shot.title,
      note: shot.note ?? game.data.summary,
      src: shot.src,
      gameTitle: game.data.title,
      label: `Scene ${index + 1}`
    }))
  )
  .slice(0, 4);
const filterGroups = [
  { label: '重点项目', value: 'featured' },
  { label: '持续迭代', value: 'ongoing' },
  { label: '可玩验证', value: 'playable' },
  { label: '展示版本', value: 'showcase' }
];
---

<BaseLayout title={`游戏作品 | ${siteMeta.name}`} description="围绕玩法验证、展示版包装、多端适配和 Web 试玩整理的项目案例。">
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '作品' }]} />
  <section class="page-heading card page-heading--rich">
    <p class="eyebrow">Games</p>
    <h1>游戏作品</h1>
    <p>这里收录围绕玩法验证、展示版收口和多端适配整理的项目案例。每个项目页都会同步当前阶段、目录聚焦、关键文档、下载入口和在线试玩方式。</p>
  </section>

  <section class="section-banner">
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">项目总数</p>
        <strong>{games.length}</strong>
        <p>当前公开可浏览的项目案例。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">重点项目</p>
        <strong>{featuredCount}</strong>
        <p>优先推荐先看的代表作。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">持续迭代</p>
        <strong>{ongoingCount}</strong>
        <p>仍在继续推进和打磨的项目。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">试玩入口</p>
        <strong>{playableCount}</strong>
        <p>已经具备 Web 或可玩验证条件的项目。</p>
      </div>
    </div>
  </section>

  {entryGame && (
    <section class="card games-entry-card">
      <div class="section-heading">
        <div>
          <h2>建议先看</h2>
          <p class="content-meta">如果你只打算先看一个项目，优先从当前最适合作为门面的案例开始。</p>
        </div>
        <a href={withBase(`/games/${entryGame.id}`)}>进入案例</a>
      </div>
      <div class="games-entry-grid">
        <div class="mini-panel">
          <p class="eyebrow">当前推荐项目</p>
          <strong>{entryGame.data.title}</strong>
          <p>{entryGame.data.summary}</p>
        </div>
        <div class="mini-panel">
          <p class="eyebrow">当前阶段</p>
          <p>{entryGame.data.currentPhase ?? gameStatusLabels[entryGame.data.status] ?? entryGame.data.status}</p>
        </div>
        <div class="mini-panel">
          <p class="eyebrow">体验方式</p>
          <p>{entryGame.data.playableWeb ? '可在线试玩，并带下载或案例入口' : '当前以案例归档和阶段说明为主'}</p>
        </div>
      </div>
    </section>
  )}

  {galleryShots.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>真实画面预览</h2>
          <p class="content-meta">统一把项目里最有代表性的画面拿出来预览，比只看封面更容易判断项目是否已经进入可展示状态。</p>
        </div>
      </div>
      <div class="project-gallery-grid">
        {galleryShots.map((shot) => (
          <a class="project-gallery-card" href={withBase(shot.href)}>
            <img src={withBase(shot.src)} alt={`${shot.gameTitle} ${shot.title}`} loading="lazy" />
            <div class="project-gallery-copy">
              <p class="eyebrow">{shot.gameTitle}</p>
              <strong>{shot.title}</strong>
              <span>{shot.note}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <ArchiveFilter
    id="games-archive"
    placeholder="搜索项目名称、目标、职责、平台或标签"
    chips={filterGroups}
    emptyMessage="没有找到匹配的项目，可以试试别的关键词或项目阶段。"
  />

  <section class="grid grid--cards-lg" data-filter-target="games-archive">
    {games.map((game) => (
      <div
        class="filter-item-shell"
        data-filter-item
        data-search={`${game.data.title} ${game.data.summary} ${game.data.description} ${game.data.role ?? ''} ${game.data.platforms.join(' ')} ${game.data.tags.join(' ')} ${gameStatusLabels[game.data.status] ?? game.data.status}`}
        data-groups={[game.data.status, game.data.featured ? 'featured' : '', game.data.playableWeb || game.data.status === 'playable' ? 'playable' : ''].filter(Boolean).join('|')}
      >
        <GameCard
          href={`/games/${game.id}`}
          title={game.data.title}
          summary={game.data.summary}
          description={game.data.description}
          status={game.data.status}
          role={game.data.role}
          platforms={game.data.platforms}
          playableWeb={game.data.playableWeb}
          thumbnail={game.data.thumbnail}
          featured={game.data.featured}
          screenshotCount={game.data.screenshots.length}
          engine={game.data.engine}
          currentPhase={game.data.currentPhase}
        />
      </div>
    ))}
  </section>
</BaseLayout>
