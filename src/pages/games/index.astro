---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveFilter from '../../components/ArchiveFilter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GameCard from '../../components/GameCard.astro';
import { withBase } from '../../utils/site';
import { sortEditorialEntries } from '../../utils/entries';
import { gameStatusLabels, siteMeta } from '../../utils/site-meta';
import { getCollectionPageSchema } from '../../utils/schema';

const games = sortEditorialEntries(await getCollection('games'));
const featuredCount = games.filter((game) => game.data.featured).length;
const playableCount = games.filter((game) => game.data.playableWeb || game.data.status === 'playable').length;
const ongoingCount = games.filter((game) => game.data.status === 'ongoing').length;
const leadGame = games.find((game) => game.data.featured) ?? games[0];
const galleryShots = games
  .flatMap((game) =>
    game.data.screenshots.slice(0, 2).map((shot, index) => ({
      href: `/games/${game.id}`,
      title: shot.title,
      note: shot.note ?? game.data.summary,
      src: shot.src,
      gameTitle: game.data.title,
      label: `Scene ${index + 1}`
    }))
  )
  .slice(0, 4);
const webDemoGames = games.filter((game) => game.data.playableWeb).slice(0, 6);
const projectPersonas: Record<string, { kicker: string; identity: string; accent: string; accent2: string; rgb: string }> = {
  'first-tetris': {
    kicker: 'Rogue Tetris Lab',
    identity: '经典计分、Rogue 实验和移动触控并行推进',
    accent: '#0078d4',
    accent2: '#00a99d',
    rgb: '0, 120, 212'
  },
  'next-spacewar': {
    kicker: 'Showcase Shooter',
    identity: '三波短任务、菜单帮助和结果页收成展示版',
    accent: '#0b7bd3',
    accent2: '#4aa3ff',
    rgb: '11, 123, 211'
  },
  intespace: {
    kicker: 'Mobile Roguelite',
    identity: '章节、生存、Boss 试炼、武器树和局外成长收口',
    accent: '#00a99d',
    accent2: '#7cddc9',
    rgb: '0, 169, 157'
  },
  raiden: {
    kicker: 'Arcade RC Build',
    identity: '纵版街机双关 Demo、连锁击破和公开试玩包装',
    accent: '#ff7a59',
    accent2: '#f4b23f',
    rgb: '255, 122, 89'
  },
  'space-war': {
    kicker: 'Retro Release',
    identity: 'Nokia 横向卷轴复刻、连续击破、Boss 和正式发布流程',
    accent: '#21a65b',
    accent2: '#9fd36a',
    rgb: '33, 166, 91'
  },
  'spacewar-ii': {
    kicker: 'Mobile Sequel Lab',
    identity: '纵向移动射击、差异化敌群、Boss 阶段和短局结算回路',
    accent: '#6f7cff',
    accent2: '#ffce5c',
    rgb: '111, 124, 255'
  }
};
const projectPlaytestCards = games
  .filter((game) => game.data.playtestVideo)
  .map((game) => ({
    game,
    persona: projectPersonas[game.id] ?? {
      kicker: 'Playable Case',
      identity: game.data.summary,
      accent: '#0078d4',
      accent2: '#00a99d',
      rgb: '0, 120, 212'
    }
  }));
const filterGroups = [
  { label: '重点项目', value: 'featured' },
  { label: '持续迭代', value: 'ongoing' },
  { label: '可玩验证', value: 'playable' },
  { label: '展示版本', value: 'showcase' },
  { label: 'Godot', value: 'godot' },
  { label: '射击项目', value: 'shooter' },
  { label: 'Roguelite', value: 'roguelite' },
  { label: '移动导向', value: 'mobile' },
  { label: '正式发布', value: 'released' }
];
const pageDescription = '围绕六个 Godot 游戏、玩法验证、展示版包装、多端适配和 Web 试玩整理的项目案例。';
const collectionSchema = getCollectionPageSchema({
  site: Astro.site,
  path: '/games',
  name: `游戏作品 | ${siteMeta.name}`,
  description: pageDescription,
  itemType: 'VideoGame',
  items: games.map((game) => ({
    name: game.data.title,
    url: `/games/${game.id}`,
    description: game.data.summary,
    image: game.data.thumbnail
  }))
});
---

<BaseLayout title={`游戏作品 | ${siteMeta.name}`} description={pageDescription} structuredData={collectionSchema}>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '作品' }]} />
  <section class="page-heading card archive-hero archive-hero--games">
    <div class="archive-hero-copy">
      <p class="eyebrow">Games</p>
      <h1>游戏作品</h1>
      <p>把 Godot 原型、Web build 和项目截图放在同一个归档里。这里优先展示能看出完成度、玩法方向和当前阶段的案例。</p>
      <div class="button-row">
        <a class="button" href="#games-archive-search">筛选项目</a>
        {webDemoGames[0]?.data.embedUrl ? (
          <a class="button button--ghost" href="#playtest-matrix">试玩切片</a>
        ) : (
          <a class="button button--ghost" href={withBase('/articles')}>阅读拆解</a>
        )}
      </div>
      <div class="archive-metrics">
        <span><strong>{games.length}</strong> 项目</span>
        <span><strong>{playableCount}</strong> 试玩</span>
        <span><strong>{featuredCount}</strong> 精选</span>
        <span><strong>{ongoingCount}</strong> 迭代中</span>
      </div>
    </div>

    {leadGame && (
      <a class="archive-feature-card archive-feature-card--game" href={withBase(`/games/${leadGame.id}`)}>
        {leadGame.data.thumbnail ? (
          <img src={withBase(leadGame.data.thumbnail)} alt={leadGame.data.title} loading="eager" decoding="async" />
        ) : null}
        <div class="archive-feature-copy">
          <p class="eyebrow">Featured Case</p>
          <strong>{leadGame.data.title}</strong>
          <span>{leadGame.data.summary}</span>
          <div class="tag-list">
            <span>{leadGame.data.engine}</span>
            <span>{leadGame.data.playableWeb ? '可在线试玩' : gameStatusLabels[leadGame.data.status]}</span>
          </div>
        </div>
      </a>
    )}
  </section>

  <section class="showcase-reel card showcase-reel--archive">
    <div class="showcase-reel-copy">
      <p class="eyebrow">Capture Reel</p>
      <h2>项目运行画面合集</h2>
      <p>
        把已有 Godot 项目的真实运行片段集中成一条预览线，先看节奏、界面和完成度，再进入单个案例页深入验证。
      </p>
      <div class="tag-list">
        <span>{games.length} 个项目</span>
        <span>真实运行采集</span>
        <span>横版展示</span>
      </div>
    </div>
    <div class="showcase-reel-media">
      <video
        controls
        playsinline
        preload="metadata"
        poster={withBase('/images/projects/project-showcase-preview.png')}
      >
        <source src={withBase('/videos/project-showcase.mp4')} type="video/mp4" />
      </video>
    </div>
  </section>

  {projectPlaytestCards.length > 0 && (
    <section id="playtest-matrix" class="card project-playtest-index">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Playtest Matrix</p>
          <h2>实机试玩切片</h2>
          <p class="content-meta">每个卡片都指向对应项目的实机试玩视频，方便快速比较玩法类型、页面完成度和当前阶段；第六个项目通过下方 Web 试玩入口承接。</p>
        </div>
      </div>
      <div class="project-playtest-index-grid">
        {projectPlaytestCards.map(({ game, persona }) => (
          <a
            class="project-playtest-index-card"
            href={withBase(`/games/${game.id}#playtest`)}
            style={`--project-accent: ${persona.accent}; --project-accent-2: ${persona.accent2}; --project-rgb: ${persona.rgb};`}
          >
            <div class="project-playtest-index-media">
              {game.data.playtestPoster || game.data.thumbnail ? (
                <img src={withBase(game.data.playtestPoster ?? game.data.thumbnail)} alt={`${game.data.title} 试玩画面`} loading="lazy" decoding="async" />
              ) : null}
              <span>看试玩视频</span>
            </div>
            <div class="project-playtest-index-copy">
              <p class="eyebrow">{persona.kicker}</p>
              <strong>{game.data.title}</strong>
              <span>{persona.identity}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <ArchiveFilter
    id="games-archive"
    placeholder="搜索项目名称、目标、职责、平台或标签"
    chips={filterGroups}
    emptyMessage="没有找到匹配的项目，可以试试别的关键词或项目阶段。"
  />

  <section class="grid grid--cards-lg" data-filter-target="games-archive">
    {games.map((game) => (
      <div
        class="filter-item-shell"
        data-filter-item
        data-search={`${game.data.title} ${game.data.summary} ${game.data.description} ${game.data.role ?? ''} ${game.data.platforms.join(' ')} ${game.data.tags.join(' ')} ${gameStatusLabels[game.data.status] ?? game.data.status}`}
        data-groups={[
          game.data.status,
          game.data.featured ? 'featured' : '',
          game.data.playableWeb || game.data.status === 'playable' ? 'playable' : '',
          /godot/i.test(game.data.engine) ? 'godot' : '',
          game.data.tags.some((tag) => /shooter|space impact|raiden|auto shooter/i.test(tag)) ? 'shooter' : '',
          game.data.tags.some((tag) => /roguelite/i.test(tag)) ? 'roguelite' : '',
          [...game.data.platforms, ...game.data.tags].some((value) => /手机|移动|touch|mobile/i.test(value)) ? 'mobile' : '',
          game.data.downloadLinks.length > 0 ? 'released' : ''
        ].filter(Boolean).join('|')}
      >
        <GameCard
          slug={game.id}
          href={`/games/${game.id}`}
          title={game.data.title}
          summary={game.data.summary}
          description={game.data.description}
          status={game.data.status}
          role={game.data.role}
          platforms={game.data.platforms}
          playableWeb={game.data.playableWeb}
          thumbnail={game.data.thumbnail}
          featured={game.data.featured}
          screenshotCount={game.data.screenshots.length}
          engine={game.data.engine}
          currentPhase={game.data.currentPhase}
          playUrl={game.data.embedUrl}
        />
      </div>
    ))}
  </section>

  {galleryShots.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>真实画面预览</h2>
          <p class="content-meta">用项目截图直接呈现完成度与视觉状态。</p>
        </div>
      </div>
      <div class="project-gallery-grid">
        {galleryShots.map((shot) => (
          <a class="project-gallery-card" href={withBase(shot.href)}>
            <img src={withBase(shot.src)} alt={`${shot.gameTitle} ${shot.title}`} loading="lazy" decoding="async" />
            <div class="project-gallery-copy">
              <p class="eyebrow">{shot.gameTitle}</p>
              <strong>{shot.title}</strong>
              <span>{shot.note}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {webDemoGames.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>当前试玩入口</h2>
          <p class="content-meta">已接通的 Web build 统一放在这里。</p>
        </div>
      </div>
      <div class="play-lane">
        {webDemoGames.map((game) => (
          <article class="play-lane-card">
            <div class="play-lane-copy">
              <p class="eyebrow">Playable Build</p>
              <strong>{game.data.title}</strong>
              <span>{game.data.currentPhase ?? game.data.summary}</span>
            </div>
            <div class="tag-list">
              <span>{game.data.engine}</span>
              <span>{gameStatusLabels[game.data.status] ?? game.data.status}</span>
            </div>
            <div class="card-actions">
              {game.data.embedUrl ? (
                <a class="button button--small" href={withBase(game.data.embedUrl)} target="_blank" rel="noopener noreferrer">打开试玩</a>
              ) : null}
              <a class="button button--ghost button--small" href={withBase(`/games/${game.id}`)}>查看案例</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
