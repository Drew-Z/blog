---
import { toSiteUrl, withBase } from '../../utils/site';

const target = withBase('/games/intespace');
const canonical = toSiteUrl('/games/intespace', Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <p>页面已迁移到 <a href={target}>{target}</a></p>
  </body>
</html>
