---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentPager from '../../components/ContentPager.astro';
import ContentToc from '../../components/ContentToc.astro';
import { withBase } from '../../utils/site';
import { getPublishedArticles } from '../../utils/content';
import { getEntryNeighbors } from '../../utils/entries';
import { estimateReadingTime, formatDate, slugifyTag } from '../../utils/site-meta';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const allArticles = await getPublishedArticles();
const relatedArticles = allArticles
  .filter((item) => item.id !== article.id)
  .map((item) => ({
    item,
    score: item.data.tags.filter((tag) => article.data.tags.includes(tag)).length
  }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.item.data.pubDate.valueOf() - a.item.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ item }) => item);
const readingTime = estimateReadingTime(article.body);
const { newer, older } = getEntryNeighbors(allArticles, (item) => item.id === article.id);
---

<BaseLayout
  title={`${article.data.title} | 文章`}
  description={article.data.description}
  image={article.data.coverImage}
  type="article"
>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '文章', href: '/articles' }, { label: article.data.title }]} />
  <article class="content-layout">
    <div class="content-main">
      <header class="content-header card content-header--article">
        <div class="content-header-copy">
          <p class="eyebrow">Article</p>
          <h1>{article.data.title}</h1>
          <p>{article.data.description}</p>
          <div class="tag-list">
            {article.data.tags.map((tag) => (
              <a href={withBase(`/articles/tags/${slugifyTag(tag)}`)}>{tag}</a>
            ))}
          </div>
        </div>
        <div class="content-meta-panel">
          {article.data.coverImage ? (
            <div class="content-header-visual">
              <img src={withBase(article.data.coverImage)} alt={article.data.title} loading="eager" decoding="async" fetchpriority="high" />
            </div>
          ) : null}
          <div class="mini-panel">
            <p class="eyebrow">发布日期</p>
            <time datetime={article.data.pubDate.toISOString()}>{formatDate(article.data.pubDate)}</time>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">阅读定位</p>
            <p>适合展示分析框架、推导过程和表达能力。</p>
          </div>
        </div>
      </header>

      <div class="prose-block prose-block--article">
        <Content />
      </div>

      {relatedArticles.length > 0 && (
        <section class="card">
          <div class="section-heading">
            <div>
              <h2>相关文章</h2>
              <p class="content-meta">这些文章和当前主题更接近，适合继续顺着往下读。</p>
            </div>
          </div>
          <div class="link-list">
            {relatedArticles.map((item) => (
              <a href={withBase(`/articles/${item.id}`)}>{item.data.title}</a>
            ))}
          </div>
        </section>
      )}

      <ContentPager
        newer={
          newer
            ? {
                href: `/articles/${newer.id}`,
                label: '更新较新',
                title: newer.data.title,
                description: newer.data.description
              }
            : undefined
        }
        older={
          older
            ? {
                href: `/articles/${older.id}`,
                label: '更早一篇',
                title: older.data.title,
                description: older.data.description
              }
            : undefined
        }
      />
    </div>

    <aside class="content-sidebar card">
      <section>
        <div class="section-heading">
          <h2>文章信息</h2>
        </div>
        <div class="meta-grid">
          <div class="mini-panel">
            <p class="eyebrow">阅读时长</p>
            <p>{readingTime}</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">标签</p>
            <div class="tag-list">
              {article.data.tags.map((tag) => (
                <a href={withBase(`/articles/tags/${slugifyTag(tag)}`)}>{tag}</a>
              ))}
            </div>
          </div>
          {article.data.updatedDate ? (
            <div class="mini-panel">
              <p class="eyebrow">最近更新</p>
              <p>{formatDate(article.data.updatedDate)}</p>
            </div>
          ) : null}
          <div class="mini-panel">
            <p class="eyebrow">用途</p>
            <p>这部分内容更偏系统设计文章、案例分析和方法论沉淀。</p>
          </div>
        </div>
      </section>

      <ContentToc headings={headings} />
    </aside>
  </article>
</BaseLayout>
