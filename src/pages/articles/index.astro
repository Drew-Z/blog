---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="文章归档 | Biau Playlab" description="系统设计文章、游戏分析和迁移后的旧博客内容。">
  <section class="page-heading card page-heading--rich">
    <p class="eyebrow">Articles</p>
    <h1>文章归档</h1>
    <p>这里保留原有博客里的长文章，也纳入了从 Quartz 迁来的内容。它们更适合展示分析能力、表达方式和方法论。</p>
    <div class="tag-list">
      <span>{articles.length} 篇文章</span>
      <span>长文优先</span>
      <span>持续可扩展</span>
    </div>
  </section>

  <section class="grid grid--cards-lg">
    {articles.map((article) => (
      <ArticleCard
        href={`/articles/${article.id}`}
        title={article.data.title}
        description={article.data.description}
        pubDate={article.data.pubDate}
        tags={article.data.tags}
        coverImage={article.data.coverImage}
        featured={article.data.featured}
      />
    ))}
  </section>
</BaseLayout>
