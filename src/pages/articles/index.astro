---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ArchiveFilter from '../../components/ArchiveFilter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { withBase } from '../../utils/site';
import { getPublishedArticles, getPublishedArticleTagCounts } from '../../utils/content';
import { formatDate, siteMeta, slugifyTag } from '../../utils/site-meta';
import { getCollectionPageSchema } from '../../utils/schema';

const articles = await getPublishedArticles();
const tagCounts = await getPublishedArticleTagCounts();
const featuredCount = articles.filter((article) => article.data.featured).length;
const tagCount = tagCounts.length;
const latestArticle = articles[0];
const latestUpdateLabel = latestArticle ? formatDate(latestArticle.data.pubDate).replace(/^\d+年/, '') : '待补充';
const leadArticle = articles.find((article) => article.data.featured) ?? latestArticle;
const hotTags = tagCounts.slice(0, 10);
const filterTags = hotTags.slice(0, 6).map(({ tag }) => ({
  label: tag,
  value: slugifyTag(tag)
}));
const pageDescription = '系统策划拆解、游戏分析和方法沉淀文章。';
const collectionSchema = getCollectionPageSchema({
  site: Astro.site,
  path: '/articles',
  name: `文章归档 | ${siteMeta.name}`,
  description: pageDescription,
  itemType: 'BlogPosting',
  items: articles.map((article) => ({
    name: article.data.title,
    url: `/articles/${article.id}`,
    description: article.data.description,
    image: article.data.coverImage
  }))
});
---

<BaseLayout title={`文章归档 | ${siteMeta.name}`} description={pageDescription} structuredData={collectionSchema}>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '文章' }]} />
  <section class="page-heading card archive-hero archive-hero--articles">
    <div class="archive-hero-copy">
      <p class="eyebrow">Articles</p>
      <h1>文章归档</h1>
      <p>系统策划拆解、游戏分析和方法沉淀集中在这里。内容更偏结构化判断：先说明系统如何运作，再落到问题、风险和可优化方向。</p>
      <div class="button-row">
        <a class="button" href="#articles-archive-search">筛选文章</a>
        <a class="button button--ghost" href={withBase('/articles/tags')}>查看标签</a>
      </div>
      <div class="archive-metrics">
        <span><strong>{articles.length}</strong> 文章</span>
        <span><strong>{featuredCount}</strong> 精选</span>
        <span><strong>{tagCount}</strong> 标签</span>
        <span><strong>{latestUpdateLabel}</strong> 更新</span>
      </div>
    </div>

    {leadArticle && (
      <a class="archive-feature-card archive-feature-card--article" href={withBase(`/articles/${leadArticle.id}`)}>
        {leadArticle.data.coverImage ? (
          <img src={withBase(leadArticle.data.coverImage)} alt={leadArticle.data.title} loading="eager" decoding="async" />
        ) : null}
        <div class="archive-feature-copy">
          <p class="eyebrow">Featured Note</p>
          <strong>{leadArticle.data.title}</strong>
          <span>{leadArticle.data.description}</span>
          <div class="tag-list">
            {leadArticle.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
          </div>
        </div>
      </a>
    )}
  </section>

  <ArchiveFilter
    id="articles-archive"
    placeholder="搜索文章标题、描述或标签"
    chips={filterTags}
    emptyMessage="没有找到匹配的文章，可以试试别的关键词或标签。"
  />

  <section class="grid grid--cards-lg" data-filter-target="articles-archive">
    {articles.map((article) => (
      <div
        class="filter-item-shell"
        data-filter-item
        data-search={`${article.data.title} ${article.data.description} ${article.data.tags.join(' ')}`}
        data-groups={article.data.tags.map((tag) => slugifyTag(tag)).join('|')}
      >
        <ArticleCard
          href={`/articles/${article.id}`}
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          coverImage={article.data.coverImage}
          featured={article.data.featured}
        />
      </div>
    ))}
  </section>

  {hotTags.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>按标签浏览</h2>
          <p class="content-meta">相近主题自动聚合，便于按方向浏览。</p>
        </div>
        <a href={withBase('/articles/tags')}>查看全部标签</a>
      </div>
      <div class="tag-cloud">
        {hotTags.map(({ tag, count }) => (
          <a class="tag-cloud-link" href={withBase(`/articles/tags/${slugifyTag(tag)}`)}>
            <span>{tag}</span>
            <strong>{count}</strong>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
