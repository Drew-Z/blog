---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ArchiveFilter from '../../components/ArchiveFilter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { withBase } from '../../utils/site';
import { getPublishedArticles, getPublishedArticleTagCounts } from '../../utils/content';
import { formatDate, siteMeta, slugifyTag } from '../../utils/site-meta';

const articles = await getPublishedArticles();
const tagCounts = await getPublishedArticleTagCounts();
const featuredCount = articles.filter((article) => article.data.featured).length;
const tagCount = tagCounts.length;
const latestArticle = articles[0];
const hotTags = tagCounts.slice(0, 10);
const entryArticle = articles[0];
const filterTags = hotTags.slice(0, 6).map(({ tag }) => ({
  label: tag,
  value: slugifyTag(tag)
}));
---

<BaseLayout title={`文章归档 | ${siteMeta.name}`} description="系统策划拆解、游戏分析和方法沉淀文章。">
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '文章' }]} />
  <section class="page-heading card page-heading--rich">
    <p class="eyebrow">Articles</p>
    <h1>文章归档</h1>
    <p>这里以系统策划拆解、游戏分析和方法沉淀为主，也保留了少量对实际工作有帮助的技术长文，更适合展示分析能力与表达质量。</p>
  </section>

  <section class="section-banner">
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">文章总数</p>
        <strong>{articles.length}</strong>
        <p>当前公开可浏览的长文内容。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">精选文章</p>
        <strong>{featuredCount}</strong>
        <p>适合第一次来时优先阅读。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">主题标签</p>
        <strong>{tagCount}</strong>
        <p>目前覆盖的主要话题范围。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">最近更新</p>
        <strong>{latestArticle ? formatDate(latestArticle.data.pubDate) : '待补充'}</strong>
        <p>保持文章入口的持续整理与沉淀。</p>
      </div>
    </div>
  </section>

  {entryArticle && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>建议起点</h2>
          <p class="content-meta">如果你是第一次看这里，先从这篇开始，通常最容易判断我的分析框架和表达密度。</p>
        </div>
        <a href={withBase(`/articles/${entryArticle.id}`)}>直接阅读</a>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">当前优先推荐</p>
        <strong>{entryArticle.data.title}</strong>
        <p>{entryArticle.data.description}</p>
      </div>
    </section>
  )}

  {hotTags.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>按标签浏览</h2>
          <p class="content-meta">把相近主题聚合在一起，适合快速判断我最常写什么、分析重心在哪里。</p>
        </div>
        <a href={withBase('/articles/tags')}>查看全部标签</a>
      </div>
      <div class="tag-cloud">
        {hotTags.map(({ tag, count }) => (
          <a class="tag-cloud-link" href={withBase(`/articles/tags/${slugifyTag(tag)}`)}>
            <span>{tag}</span>
            <strong>{count}</strong>
          </a>
        ))}
      </div>
    </section>
  )}

  <ArchiveFilter
    id="articles-archive"
    placeholder="搜索文章标题、描述或标签"
    chips={filterTags}
    emptyMessage="没有找到匹配的文章，可以试试别的关键词或标签。"
  />

  <section class="grid grid--cards-lg" data-filter-target="articles-archive">
    {articles.map((article) => (
      <div
        class="filter-item-shell"
        data-filter-item
        data-search={`${article.data.title} ${article.data.description} ${article.data.tags.join(' ')}`}
        data-groups={article.data.tags.map((tag) => slugifyTag(tag)).join('|')}
      >
        <ArticleCard
          href={`/articles/${article.id}`}
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          coverImage={article.data.coverImage}
          featured={article.data.featured}
        />
      </div>
    ))}
  </section>
</BaseLayout>
