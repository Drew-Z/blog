---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { withBase } from '../utils/site';
import { getArticleWorkbenchStats, getPublishedArticles } from '../utils/content';
import { siteMeta } from '../utils/site-meta';

const games = await getCollection('games');
const logs = await getCollection('devlogs');
const articles = await getPublishedArticles();
const articleWorkbenchStats = await getArticleWorkbenchStats();
---

<BaseLayout title={`关于 | ${siteMeta.name}`} description="这个作品展示博客的定位、内容结构与当前关注。">
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '关于' }]} />
  <section class="page-heading card page-heading--rich">
    <p class="eyebrow">About</p>
    <h1>这是一个围绕独立游戏原型、系统设计与开发写作搭建的个人作品展示博客。</h1>
    <p>
      这里不是单纯的资料堆积页，也不是只放截图的作品页。我把项目案例、开发过程和长文章放在同一个入口里，让访客能同时看到“做了什么”和“为什么这样做”。
    </p>
    <div class="tag-list">
      <span>{games.length} 个项目</span>
      <span>{logs.length} 篇日志</span>
      <span>{articles.length} 篇文章</span>
    </div>
  </section>

  <section class="section-banner">
    <div class="section-heading">
      <h2>这个站里主要有什么</h2>
    </div>
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">作品案例</p>
        <p>围绕 Godot 原型、展示版收口和多端适配整理项目案例，强调目标、阶段、职责和下一步计划。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">开发日志</p>
        <p>记录功能推进、方案取舍与阶段结论，让外部也能看懂项目是怎么一步步收口的。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">深度文章</p>
        <p>用系统策划拆解、游戏分析和方法沉淀补足“表达能力”和“结构化思考”这一层。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">发布流</p>
        <p>公开文章和内部素材已经分开维护，正式发布内容统一走站点文章入口，避免素材库和公开站混在一起。</p>
      </div>
    </div>
  </section>

  <section class="content-layout card-stack">
    <div class="content-main">
      <section class="card">
        <div class="section-heading">
          <h2>我重点在做什么</h2>
        </div>
        <div class="feature-grid">
          <div class="mini-panel">
            <p class="eyebrow">玩法原型</p>
            <p>把核心循环先做出来，再逐步补足外层入口、反馈结构和可展示性，而不是停在开发态原型。</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">系统拆解</p>
            <p>用长文章把复杂系统拆成可说明的结构，训练自己也帮助别人快速理解设计逻辑。</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">开发复盘</p>
            <p>把“做了什么”之外的判断、取舍和踩坑记录下来，让过程也成为作品的一部分。</p>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="section-heading">
          <h2>建议浏览顺序</h2>
        </div>
        <ol class="timeline-list">
          <li>先从作品页进入，快速看代表项目的目标、阶段和关键画面。</li>
          <li>再读一篇关联日志，理解这个项目是怎么推进和收口的。</li>
          <li>最后选一篇系统拆解或方法文章，看我如何表达复杂内容和组织分析框架。</li>
        </ol>
      </section>

      <section class="card">
        <div class="section-heading">
          <h2>后续会继续补什么</h2>
        </div>
        <ul class="timeline-list">
          <li>为项目补更完整的录屏、真实截图和可试玩入口。</li>
          <li>给重点项目增加更清晰的版本时间线和里程碑说明。</li>
          <li>持续筛选零散笔记，只把真正值得公开的内容整理进主站。</li>
        </ul>
      </section>
    </div>

    <aside class="content-sidebar card">
      <section>
        <div class="section-heading">
          <h2>站点速览</h2>
        </div>
        <div class="meta-grid">
          <div class="mini-panel">
            <p class="eyebrow">定位</p>
            <p>作品展示博客</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">方向</p>
            <p>Godot 原型 / 系统策划 / 开发写作</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">技术栈</p>
            <p>Astro + Content Collections</p>
          </div>
          <div class="mini-panel">
            <p class="eyebrow">公开文章</p>
            <p>{articles.length} 篇已发布 / {articleWorkbenchStats.drafts} 篇内部素材</p>
            {articleWorkbenchStats.duplicates > 0 ? <p>其中 {articleWorkbenchStats.duplicates} 篇是与公开稿重复的历史版本。</p> : null}
          </div>
        </div>
      </section>

      <section>
        <div class="section-heading">
          <h2>快速入口</h2>
        </div>
        <div class="link-list">
          <a href={withBase('/games')}>查看游戏作品</a>
          <a href={withBase('/logs')}>查看开发日志</a>
          <a href={withBase('/articles')}>查看文章归档</a>
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>
