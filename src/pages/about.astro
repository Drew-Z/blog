---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { withBase } from '../utils/site';
import { getArticleWorkbenchStats, getPublishedArticles } from '../utils/content';
import { profileFocusAreas, siteMeta } from '../utils/site-meta';
import { getProfilePageSchema } from '../utils/schema';

const games = await getCollection('games');
const articles = await getPublishedArticles();
const articleWorkbenchStats = await getArticleWorkbenchStats();
const profileSchema = getProfilePageSchema(Astro.site);

const workingMethods = [
  {
    step: '01',
    title: '先验证核心循环',
    summary: '把规则、输入和反馈压到一个可玩的最小版本里，先确认它是否真的成立。'
  },
  {
    step: '02',
    title: '再整理系统结构',
    summary: '把体验拆成目标、资源、限制和反馈，记录每一次取舍背后的判断。'
  },
  {
    step: '03',
    title: '最后收成可阅读案例',
    summary: '补齐截图、试玩入口、阶段状态和文章说明，让第一次打开的人也能快速理解。'
  }
];

const upcomingNotes = [
  '为重点项目补更完整的录屏、真实截图和试玩入口。',
  '补充版本时间线、里程碑和关键设计取舍。',
  '继续把零散笔记筛成可公开文章，只保留真正值得阅读的内容。'
];

const nowNotes = [
  { label: '当前方向', value: 'Godot 原型 / 系统策划 / 内容表达' },
  { label: '内容状态', value: `${articles.length} 篇公开文章，${articleWorkbenchStats.drafts} 篇内部素材` },
  { label: '站点技术', value: 'Astro 静态站点，内容集合管理' }
];
---

<BaseLayout title={`关于 | ${siteMeta.name}`} description="这个作品集的定位、内容结构与当前关注。" structuredData={profileSchema}>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '关于' }]} />
  <section class="page-heading card archive-hero about-hero">
    <div class="archive-hero-copy">
      <p class="eyebrow">About / Practice</p>
      <h1>做可验证的游戏原型，也把系统判断写清楚。</h1>
      <p>
        这个站点收集我在玩法原型、系统拆解和内容表达上的练习：先把想法做成能试玩的东西，
        再把过程整理成别人能看懂、能复盘的案例。
      </p>
      <div class="button-row">
        <a class="button" href={withBase('/games')}>查看作品</a>
        <a class="button button--ghost" href={withBase('/articles')}>阅读文章</a>
      </div>
      <div class="archive-metrics">
        <span><strong>{games.length}</strong> 公开项目</span>
        <span><strong>{articles.length}</strong> 公开文章</span>
        <span><strong>{articleWorkbenchStats.drafts}</strong> 素材池</span>
      </div>
    </div>

    <div class="about-signal-card" aria-hidden="true">
      <div class="about-signal-header">
        <span>Working loop</span>
        <strong>Idea / Prototype / Case</strong>
      </div>
      <div class="about-orbit">
        <span class="orbit-core">Playtest</span>
        <span class="orbit-dot orbit-dot--one"></span>
        <span class="orbit-dot orbit-dot--two"></span>
        <span class="orbit-dot orbit-dot--three"></span>
      </div>
      <div class="about-signal-stack">
        <span><strong>Prototype</strong><em>core loop</em></span>
        <span><strong>Systems</strong><em>decision map</em></span>
        <span><strong>Writing</strong><em>public case</em></span>
      </div>
    </div>
  </section>

  <section class="content-layout card-stack">
    <div class="content-main">
      <section class="card">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Method</p>
            <h2>我怎样推进一个想法</h2>
          </div>
        </div>
        <div class="about-method-grid">
          {workingMethods.map((item) => (
            <article class="about-method-card">
              <span>{item.step}</span>
              <strong>{item.title}</strong>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Positioning</p>
            <h2>能力定位</h2>
          </div>
          <p class="content-meta">这个作品集主要围绕三类能力展开。</p>
        </div>
        <div class="positioning-grid">
          {profileFocusAreas.map((item) => (
            <article class="positioning-card">
              <p class="eyebrow">Focus</p>
              <strong>{item.title}</strong>
              <span class="positioning-ratio">{item.ratio}</span>
              <span class="positioning-meter" style={`--value: ${item.ratio}`}></span>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Next</p>
            <h2>近期会补齐什么</h2>
          </div>
        </div>
        <ol class="about-roadmap">
          {upcomingNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ol>
      </section>
    </div>

    <aside class="content-sidebar card about-sidebar">
      <section>
        <div class="section-heading">
          <h2>当前状态</h2>
        </div>
        <div class="about-now-list">
          {nowNotes.map((item) => (
            <div class="about-now-item">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </section>

      <section>
        <div class="section-heading">
          <h2>入口</h2>
        </div>
        <div class="link-list">
          <a href={withBase('/games')}>查看游戏作品</a>
          <a href={withBase('/articles')}>查看文章归档</a>
          <a href={siteMeta.githubProfile} target="_blank" rel="noopener noreferrer">打开 GitHub Profile</a>
          <a href={siteMeta.repository} target="_blank" rel="noopener noreferrer">查看站点仓库</a>
          <a href={withBase(siteMeta.rss)}>订阅 RSS</a>
        </div>
      </section>

      <section class="bilingual-card mini-panel">
        <p class="eyebrow">English</p>
        <p class="bilingual-lead">{siteMeta.englishDescription}</p>
      </section>
    </aside>
  </section>
</BaseLayout>
