---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GameCard from '../components/GameCard.astro';
import DevlogCard from '../components/DevlogCard.astro';
import { withBase } from '../utils/site';
import { getPublishedArticles } from '../utils/content';
import { sortEditorialEntries } from '../utils/entries';
import { devlogProjectLabels, gameStatusLabels, profileFocusAreas, siteMeta } from '../utils/site-meta';

const games = sortEditorialEntries(await getCollection('games'));
const logs = sortEditorialEntries(await getCollection('devlogs'));
const articles = await getPublishedArticles();

const featuredGames = games.filter((item) => item.data.featured).slice(0, 3);
const featuredLogs = logs.filter((item) => item.data.featured).slice(0, 3);
const featuredArticles = articles.filter((item) => item.data.featured).slice(0, 3);

const homeGames = featuredGames.length > 0 ? featuredGames : games.slice(0, 3);
const homeLogs = featuredLogs.length > 0 ? featuredLogs : logs.slice(0, 3);
const homeArticles = featuredArticles.length > 0 ? featuredArticles : articles.slice(0, 3);

const spotlightGame = homeGames[0];
const spotlightLog = homeLogs[0];
const spotlightArticle = homeArticles[0];
const playableCount = games.filter((item) => item.data.playableWeb).length;
const downloadableCount = games.filter((item) => item.data.downloadLinks.length > 0).length;
const trackedProjects = games.slice(0, 5);
const entryRoute = [
  homeGames[0] ? { label: '先看代表项目', href: `/games/${homeGames[0].slug}`, title: homeGames[0].data.title } : undefined,
  homeLogs[0] ? { label: '再看阶段日志', href: `/logs/${homeLogs[0].slug}`, title: homeLogs[0].data.title } : undefined,
  homeArticles[0] ? { label: '最后读长文', href: `/articles/${homeArticles[0].id}`, title: homeArticles[0].data.title } : undefined
].filter(Boolean);
---

<BaseLayout title={`${siteMeta.name} | ${siteMeta.title}`} description={siteMeta.description}>
  <section class="hero hero--home">
    <div class="hero-copy">
      <p class="eyebrow">Portfolio Blog</p>
      <h1>把游戏原型、阶段决策、目录结构和展示收口放在同一个作品站里。</h1>
      <p>
        {siteMeta.description}
        这里不只展示“做了什么”，也会同步“现在做到哪里、目录怎么组织、下一步准备怎么推进”，更适合招聘评估、合作沟通和阶段复盘时快速建立理解。
      </p>
      <div class="button-row">
        <a class="button" href={withBase('/games')}>查看项目案例</a>
        <a class="button button--ghost" href={withBase('/logs')}>浏览开发日志</a>
      </div>
      <div class="tag-list">
        <span>Godot 原型</span>
        <span>系统策划</span>
        <span>进度同步</span>
        <span>Web 试玩</span>
      </div>
    </div>

    <div class="hero-panel">
      <div class="kpi-grid">
        <div class="mini-panel">
          <strong>{games.length}</strong>
          <p>个项目案例</p>
        </div>
        <div class="mini-panel">
          <strong>{playableCount}</strong>
          <p>个在线试玩入口</p>
        </div>
        <div class="mini-panel">
          <strong>{downloadableCount}</strong>
          <p>个下载体验入口</p>
        </div>
      </div>

      {spotlightGame && (
        <a class="hero-spotlight-card" href={withBase(`/games/${spotlightGame.slug}`)}>
          <p class="eyebrow">当前门面项目</p>
          <strong>{spotlightGame.data.title}</strong>
          <span>{spotlightGame.data.summary}</span>
          <div class="tag-list">
            <span>{spotlightGame.data.currentPhase ?? gameStatusLabels[spotlightGame.data.status]}</span>
            <span>{spotlightGame.data.playableWeb ? '可在线试玩' : '案例展示'}</span>
          </div>
        </a>
      )}
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>五个项目总览</h2>
        <p class="content-meta">把当前阶段、入口形式和下一步意图统一压成一屏，方便先看全局再深入单个项目。</p>
      </div>
      <a href={withBase('/games')}>进入作品页</a>
    </div>
    <div class="project-matrix">
      {trackedProjects.map((game) => (
        <a class="project-status-card" href={withBase(`/games/${game.slug}`)}>
          <div class="project-status-head">
            <strong>{game.data.title}</strong>
            <span class:list={['status-pill', game.data.playableWeb && 'status-pill--active']}>
              {game.data.playableWeb ? '可试玩' : gameStatusLabels[game.data.status]}
            </span>
          </div>
          <p>{game.data.currentPhase ?? game.data.summary}</p>
          <div class="meta-stack">
            <span>平台：{game.data.platforms.join(' / ') || '待补充'}</span>
            <span>
              入口：
              {game.data.playableWeb
                ? ' 在线试玩'
                : game.data.downloadLinks.length > 0
                  ? ' 下载 / 外链体验'
                  : ' 案例页阅读'}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section-banner">
    <div class="section-heading">
      <div>
        <h2>第一次来，建议这样浏览</h2>
        <p class="content-meta">先看项目，再看过程，最后看方法论，理解效率最高。</p>
      </div>
    </div>
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">01 项目案例</p>
        <p>先看作品页，快速知道项目类型、当前阶段、目录结构、试玩入口和核心职责。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">02 开发日志</p>
        <p>再看阶段日志，理解这些项目是怎么一步步收口、为什么这样做、做了哪些取舍。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">03 深度文章</p>
        <p>最后读系统设计和游戏拆解文章，看分析框架、表达组织和判断方式。</p>
      </div>
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>个人定位</h2>
        <p class="content-meta">如果你想快速判断我更偏哪一类工作，可以先看这三个重点方向。</p>
      </div>
      <a href={withBase('/about')}>查看详细说明</a>
    </div>
    <div class="positioning-grid">
      {profileFocusAreas.map((item) => (
        <article class="positioning-card">
          <p class="eyebrow">Focus</p>
          <strong>{item.title}</strong>
          <span class="positioning-ratio">{item.ratio}</span>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  {entryRoute.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>推荐起点</h2>
          <p class="content-meta">如果你想在最短时间内建立整体印象，可以直接按这条路线往下看。</p>
        </div>
      </div>
      <div class="route-grid">
        {entryRoute.map((item) => (
          <a class="route-card" href={withBase(item!.href)}>
            <p class="eyebrow">{item!.label}</p>
            <strong>{item!.title}</strong>
          </a>
        ))}
      </div>
    </section>
  )}

  {(spotlightGame || spotlightLog || spotlightArticle) && (
    <section class="card spotlight-shell">
      <div class="section-heading">
        <div>
          <h2>编辑主推</h2>
          <p class="content-meta">把最适合作为门面、过程入口和方法论入口的内容单独拎出来，方便第一次访问时快速建立完整印象。</p>
        </div>
      </div>
      <div class="spotlight-grid">
        {spotlightGame && (
          <a class="spotlight-primary" href={withBase(`/games/${spotlightGame.slug}`)}>
            <p class="eyebrow">Featured Project</p>
            <strong>{spotlightGame.data.title}</strong>
            <p>{spotlightGame.data.summary}</p>
            <div class="tag-list">
              {spotlightGame.data.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
            </div>
          </a>
        )}
        <div class="spotlight-side">
          {spotlightLog && (
            <a class="editor-pick-card" href={withBase(`/logs/${spotlightLog.slug}`)}>
              <p class="eyebrow">Process Pick</p>
              <strong>{spotlightLog.data.title}</strong>
              <p>{devlogProjectLabels[spotlightLog.data.project] ?? spotlightLog.data.project}</p>
              <span>{spotlightLog.data.description}</span>
            </a>
          )}
          {spotlightArticle && (
            <a class="editor-pick-card" href={withBase(`/articles/${spotlightArticle.id}`)}>
              <p class="eyebrow">Method Pick</p>
              <strong>{spotlightArticle.data.title}</strong>
              <p>{spotlightArticle.data.tags.slice(0, 3).join(' / ') || '系统分析'}</p>
              <span>{spotlightArticle.data.description}</span>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>近期作品</h2>
        <p class="content-meta">优先展示当前最值得先看的项目案例。</p>
      </div>
      <a href={withBase('/games')}>查看全部项目</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeGames.map((game) => (
        <GameCard
          href={`/games/${game.slug}`}
          title={game.data.title}
          summary={game.data.summary}
          description={game.data.description}
          status={game.data.status}
          role={game.data.role}
          platforms={game.data.platforms}
          playableWeb={game.data.playableWeb}
          thumbnail={game.data.thumbnail}
          featured={game.data.featured}
          screenshotCount={game.data.screenshots.length}
          engine={game.data.engine}
          currentPhase={game.data.currentPhase}
        />
      ))}
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>近期日志</h2>
        <p class="content-meta">这些内容更适合解释项目是怎么一步步推进成现在这个样子的。</p>
      </div>
      <a href={withBase('/logs')}>查看全部日志</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeLogs.map((log) => (
        <DevlogCard
          href={`/logs/${log.slug}`}
          title={log.data.title}
          description={log.data.description}
          pubDate={log.data.pubDate}
          tags={log.data.tags}
          project={devlogProjectLabels[log.data.project] ?? log.data.project}
          featured={log.data.featured}
        />
      ))}
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>精选文章</h2>
        <p class="content-meta">如果你更关心分析框架、表达方式和系统判断，可以从这里进入。</p>
      </div>
      <a href={withBase('/articles')}>查看全部文章</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeArticles.map((article) => (
        <ArticleCard
          href={`/articles/${article.id}`}
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          coverImage={article.data.coverImage}
          featured={article.data.featured}
        />
      ))}
    </div>
  </section>

  <section class="card bilingual-card">
    <div class="section-heading">
      <div>
        <h2>English Summary</h2>
        <p class="content-meta">A compact overview for portfolio sharing, cross-team handoff, or readers who prefer English first.</p>
      </div>
    </div>
    <p class="bilingual-lead">{siteMeta.englishDescription}</p>
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">What You’ll Find</p>
        <p>Playable game cases, development logs, and long-form systems writing collected in one portfolio blog.</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">Best Fit</p>
        <p>Prototype design, systems thinking, structured writing, and packaging projects into showcase-ready case studies.</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">Suggested Route</p>
        <p>Start from a featured project, continue with a devlog, then move to a systems article for methodology and communication style.</p>
      </div>
    </div>
  </section>
</BaseLayout>
