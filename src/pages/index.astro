---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GameCard from '../components/GameCard.astro';
import { toSiteUrl, withBase } from '../utils/site';
import { getPublishedArticles } from '../utils/content';
import { sortEditorialEntries } from '../utils/entries';
import { profileFocusAreas, siteMeta } from '../utils/site-meta';
import { getAuthorSchema, getWebSiteSchema } from '../utils/schema';

const games = sortEditorialEntries(await getCollection('games'));
const articles = await getPublishedArticles();

const featuredGames = games.filter((item) => item.data.featured).slice(0, 3);
const featuredArticles = articles.filter((item) => item.data.featured).slice(0, 3);

const homeGames = featuredGames.length > 0 ? featuredGames : games.slice(0, 3);
const homeArticles = featuredArticles.length > 0 ? featuredArticles : articles.slice(0, 3);
const latestArticles = articles.slice(0, 3);

const playableCount = games.filter((item) => item.data.playableWeb).length;
const devlogs = sortEditorialEntries(await getCollection('devlogs'));
const webDemoGames = games.filter((item) => item.data.playableWeb).slice(0, 6);
const homePlayableGames = webDemoGames.slice(0, 3);
const homeUrl = toSiteUrl('/', Astro.site);
const homeSchema = [
  getWebSiteSchema(Astro.site),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${homeUrl}#webpage`,
    name: `${siteMeta.name} | ${siteMeta.title}`,
    description: siteMeta.description,
    url: homeUrl,
    inLanguage: 'zh-CN',
    isPartOf: { '@id': `${homeUrl}#website` },
    about: getAuthorSchema(Astro.site)
  }
];
---

<BaseLayout title={`${siteMeta.name} | ${siteMeta.title}`} description={siteMeta.description} structuredData={homeSchema}>
  <section class="home-banner tech-story-banner" aria-label="博客内容动态横幅">
    <div class="banner-copy">
      <p class="eyebrow">Games / Devlogs / Playable Portfolio</p>
      <h1>六个 Godot 原型与可试玩内容站。</h1>
      <p>围绕游戏系统、关卡节奏和原型验证写作，也把能运行的 Web Demo 放在同一个入口里，方便从思路一路看到可玩的结果。</p>
      <div class="button-row">
        <a class="button" href={withBase('/articles')}>阅读文章</a>
        <a class="button button--ghost" href={withBase('/games')}>查看作品</a>
      </div>
      <div class="tag-list">
        <span>{articles.length} 篇文章</span>
        <span>{games.length} 个游戏</span>
        <span>{playableCount} 个试玩入口</span>
        <span>{devlogs.length} 篇开发日志</span>
      </div>
    </div>

    <div class="banner-visual" aria-hidden="true">
      <div class="signal-track signal-track--top">
        <span></span>
      </div>
      <div class="banner-panel article-stream">
        <div class="panel-head">
          <span>Article Stream</span>
          <i></i>
        </div>
        <div class="article-lines">
          <span style="--line: 84%"></span>
          <span style="--line: 68%"></span>
          <span style="--line: 76%"></span>
          <span style="--line: 52%"></span>
        </div>
        <div class="tag-list">
          <span>系统策划</span>
          <span>游戏拆解</span>
        </div>
      </div>

      <div class="banner-panel prototype-window">
        <div class="panel-head">
          <span>Godot Prototype</span>
          <i></i>
        </div>
        <div class="prototype-stage">
          <span class="playfield-grid"></span>
          <span class="player-block"></span>
          <span class="target-block target-block--one"></span>
          <span class="target-block target-block--two"></span>
          <span class="motion-trail"></span>
        </div>
      </div>

      <div class="banner-panel system-loop">
        <div class="loop-step loop-step--one">观察</div>
        <div class="loop-step loop-step--two">拆解</div>
        <div class="loop-step loop-step--three">验证</div>
        <div class="loop-path"></div>
      </div>
      <div class="signal-track signal-track--bottom">
        <span></span>
      </div>
    </div>
  </section>

  <section class="showcase-reel home-showcase-reel card">
    <div class="showcase-reel-copy">
      <p class="eyebrow">Project Reel</p>
      <h2>项目动态预览。</h2>
      <p>
        用一段短视频先扫过当前原型的画面气质，再进入详情页看玩法目标、实现阶段和试玩入口。
      </p>
      <div class="tag-list">
        <span>Godot 4.6</span>
        <span>12 秒展示</span>
        <span>1920×1080</span>
      </div>
    </div>
    <div class="showcase-reel-media">
      <video
        controls
        playsinline
        preload="metadata"
        poster={withBase('/images/projects/project-showcase-preview.png')}
      >
        <source src={withBase('/videos/project-showcase.mp4')} type="video/mp4" />
      </video>
    </div>
  </section>

  <section class="content-dashboard content-dashboard--blog">
    <div class="card">
      <div class="section-heading">
        <div>
          <h2>最新文章</h2>
          <p class="content-meta">近期更新的系统拆解、开发笔记和玩法观察。</p>
        </div>
        <a href={withBase('/articles')}>全部文章</a>
      </div>
      <div class="compact-list home-article-list">
        {latestArticles.map((article) => (
          <ArticleCard
            href={`/articles/${article.id}`}
            title={article.data.title}
            description={article.data.description}
            pubDate={article.data.pubDate}
            tags={article.data.tags}
            coverImage={article.data.coverImage}
            featured={article.data.featured}
          />
        ))}
      </div>
    </div>

    <aside class="side-stack">
      <section class="card index-card">
        <div class="section-heading">
          <div>
            <h2>内容索引</h2>
            <p class="content-meta">按阅读、项目和标签快速进入。</p>
          </div>
        </div>
        <div class="link-list">
          <a href={withBase('/articles')}>系统策划拆解</a>
          <a href={withBase('/games')}>Godot 项目案例</a>
          <a href={withBase('/logs')}>开发日志</a>
          <a href={withBase('/articles/tags')}>文章标签</a>
          <a href={withBase('/about')}>关于我</a>
        </div>
      </section>

      {homeArticles[0] && (
        <a class="editor-pick-card editor-pick-card--light" href={withBase(`/articles/${homeArticles[0].id}`)}>
          <p class="eyebrow">Featured Article</p>
          <strong>{homeArticles[0].data.title}</strong>
          <p>{homeArticles[0].data.tags.slice(0, 3).join(' / ') || '系统分析'}</p>
          <span>{homeArticles[0].data.description}</span>
        </a>
      )}
    </aside>
  </section>

  {homePlayableGames.length > 0 && (
    <section class="card home-play-section">
      <div class="section-heading">
        <div>
          <h2>试玩入口</h2>
          <p class="content-meta">三款可直接打开的 Web Demo，更多版本在作品页继续浏览。</p>
        </div>
        <a href={withBase('/games#playtest-matrix')}>全部试玩</a>
      </div>
      <div class="play-lane">
        {homePlayableGames.map((game) => (
          <article class="play-lane-card">
            <div class="play-lane-copy">
              <p class="eyebrow">Web Demo</p>
              <strong>{game.data.title}</strong>
              <span>{game.data.currentPhase ?? game.data.summary}</span>
            </div>
            <div class="tag-list">
              <span>{game.data.engine}</span>
              <span>{game.data.platforms.join(' / ')}</span>
            </div>
            <div class="card-actions">
              {game.data.embedUrl ? (
                <a class="button button--small" href={withBase(game.data.embedUrl)} target="_blank" rel="noopener noreferrer">立即试玩</a>
              ) : null}
              <a class="button button--ghost button--small" href={withBase(`/games/${game.id}`)}>项目详情</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="card home-featured-projects">
    <div class="section-heading">
      <div>
        <h2>精选项目</h2>
        <p class="content-meta">按完成度、玩法目标和可试玩状态挑出的代表项目。</p>
      </div>
      <a href={withBase('/games')}>全部项目</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeGames.map((game) => (
        <GameCard
          slug={game.id}
          href={`/games/${game.id}`}
          title={game.data.title}
          summary={game.data.summary}
          description={game.data.description}
          status={game.data.status}
          role={game.data.role}
          platforms={game.data.platforms}
          playableWeb={game.data.playableWeb}
          thumbnail={game.data.thumbnail}
          featured={game.data.featured}
          screenshotCount={game.data.screenshots.length}
          engine={game.data.engine}
          currentPhase={game.data.currentPhase}
          playUrl={game.data.embedUrl}
        />
      ))}
    </div>
  </section>

  <section class="card">
    <div class="section-heading">
      <div>
        <h2>工作重心</h2>
        <p class="content-meta">把分析、原型和表达收束成可持续迭代的作品链路。</p>
      </div>
      <a href={withBase('/about')}>详细说明</a>
    </div>
    <div class="positioning-grid">
      {profileFocusAreas.map((item) => (
        <article class="positioning-card">
          <p class="eyebrow">Focus</p>
          <strong>{item.title}</strong>
          <span class="positioning-ratio">{item.ratio}</span>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
