---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GameCard from '../components/GameCard.astro';
import DevlogCard from '../components/DevlogCard.astro';
import { withBase } from '../utils/site';
import { getPublishedArticles } from '../utils/content';
import { sortEditorialEntries } from '../utils/entries';
import { siteMeta } from '../utils/site-meta';

const games = sortEditorialEntries(await getCollection('games'));
const logs = sortEditorialEntries(await getCollection('devlogs'));
const articles = await getPublishedArticles();

const featuredGames = games.filter((item) => item.data.featured).slice(0, 3);
const featuredLogs = logs.filter((item) => item.data.featured).slice(0, 3);
const featuredArticles = articles.filter((item) => item.data.featured).slice(0, 3);

const homeGames = featuredGames.length > 0 ? featuredGames : games.slice(0, 3);
const homeLogs = featuredLogs.length > 0 ? featuredLogs : logs.slice(0, 3);
const homeArticles = featuredArticles.length > 0 ? featuredArticles : articles.slice(0, 3);
const latestLog = logs[0];
const latestArticle = articles[0];
const entryRoute = [
  homeGames[0] ? { label: '先看代表项目', href: `/games/${homeGames[0].slug}`, title: homeGames[0].data.title } : undefined,
  homeLogs[0] ? { label: '再看阶段日志', href: `/logs/${homeLogs[0].slug}`, title: homeLogs[0].data.title } : undefined,
  homeArticles[0] ? { label: '最后读长文', href: `/articles/${homeArticles[0].id}`, title: homeArticles[0].data.title } : undefined
].filter(Boolean);
---

<BaseLayout title={`${siteMeta.name} | ${siteMeta.title}`} description={siteMeta.description}>
  <section class="hero hero--home">
    <div class="hero-copy">
      <p class="eyebrow">Portfolio Blog</p>
      <h1>用游戏原型、系统拆解和开发日志，展示一个项目从想法到落地的全过程。</h1>
      <p>
        {siteMeta.description}
        这里既有能直接浏览的项目案例，也有记录设计判断和迭代过程的日志与长文，更适合招聘、合作和同行交流时快速建立理解。
      </p>
      <div class="button-row">
        <a class="button" href={withBase('/games')}>查看作品案例</a>
        <a class="button button--ghost" href={withBase('/articles')}>阅读精选文章</a>
      </div>
      <div class="tag-list">
        <span>Godot 原型</span>
        <span>系统策划</span>
        <span>玩法验证</span>
        <span>开发复盘</span>
      </div>
    </div>

    <div class="hero-panel">
      <p class="eyebrow">Site Snapshot</p>
      <div class="kpi-grid">
        <div class="mini-panel">
          <strong>{games.length}</strong>
          <p>个项目案例</p>
        </div>
        <div class="mini-panel">
          <strong>{logs.length}</strong>
          <p>篇开发日志</p>
        </div>
        <div class="mini-panel">
          <strong>{articles.length}</strong>
          <p>篇公开文章</p>
        </div>
      </div>

      <div class="mini-panel">
        <p class="eyebrow">当前重点</p>
        <ul class="timeline-list">
          <li>把玩法原型收成更适合展示和投递的项目案例。</li>
          <li>用开发日志沉淀关键设计判断，而不只是记录结果。</li>
          <li>通过系统拆解文章补齐方法论与分析深度。</li>
        </ul>
      </div>

      <div class="mini-panel">
        <p class="eyebrow">最近更新</p>
        <div class="link-list">
          {latestLog ? <a href={withBase(`/logs/${latestLog.slug}`)}>最新日志：{latestLog.data.title}</a> : null}
          {latestArticle ? <a href={withBase(`/articles/${latestArticle.id}`)}>最新文章：{latestArticle.data.title}</a> : null}
          <a href={withBase('/about')}>查看站点介绍与浏览建议</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-banner">
    <div class="section-heading">
      <div>
        <h2>第一次来，建议这样浏览</h2>
        <p class="content-meta">先看代表作，再看过程，最后读方法论，理解效率最高。</p>
      </div>
    </div>
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">01 作品案例</p>
        <p>先看游戏项目页，快速了解我在做什么、项目到了什么阶段，以及核心能力落在什么地方。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">02 开发日志</p>
        <p>再看阶段日志，理解这些项目是如何收口、为什么这么做，以及中间有哪些判断与取舍。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">03 深度文章</p>
        <p>最后读系统设计和游戏拆解文章，看到我如何组织分析框架、表达复杂内容以及做出判断。</p>
      </div>
    </div>
  </section>

  {entryRoute.length > 0 && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>推荐起点</h2>
          <p class="content-meta">如果你想在最短时间内建立整体印象，可以直接按这条路线往下看。</p>
        </div>
      </div>
      <div class="route-grid">
        {entryRoute.map((item) => (
          <a class="route-card" href={withBase(item!.href)}>
            <p class="eyebrow">{item!.label}</p>
            <strong>{item!.title}</strong>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="home-section">
    <div class="section-heading">
      <div>
        <h2>精选作品</h2>
        <p class="content-meta">围绕玩法验证、展示版包装与多端适配整理的代表项目。</p>
      </div>
      <a href={withBase('/games')}>查看全部</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeGames.map((game) => (
        <GameCard
          href={`/games/${game.slug}`}
          title={game.data.title}
          summary={game.data.summary}
          description={game.data.description}
          status={game.data.status}
          role={game.data.role}
          platforms={game.data.platforms}
          playableWeb={game.data.playableWeb}
          thumbnail={game.data.thumbnail}
          featured={game.data.featured}
        />
      ))}
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <div>
        <h2>最新开发日志</h2>
        <p class="content-meta">记录阶段推进、方案取舍与版本收口，让项目过程也能被外部看懂。</p>
      </div>
      <a href={withBase('/logs')}>进入日志页</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeLogs.map((log) => (
        <DevlogCard
          href={`/logs/${log.slug}`}
          title={log.data.title}
          description={log.data.description}
          pubDate={log.data.pubDate}
          tags={log.data.tags}
          project={log.data.project}
          featured={log.data.featured}
        />
      ))}
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <div>
        <h2>精选文章</h2>
        <p class="content-meta">以系统策划拆解、游戏分析和方法沉淀为主的长篇内容。</p>
      </div>
      <a href={withBase('/articles')}>查看归档</a>
    </div>
    <div class="grid grid--cards-lg">
      {homeArticles.map((article) => (
        <ArticleCard
          href={`/articles/${article.id}`}
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          coverImage={article.data.coverImage}
          featured={article.data.featured}
        />
      ))}
    </div>
  </section>

  <section class="section-banner">
    <div class="section-heading">
      <div>
        <h2>这个站更适合用于什么场景</h2>
        <p class="content-meta">不只是写博客，而是为投递、合作和同行交流准备的统一入口。</p>
      </div>
      <a href={withBase('/about')}>查看关于页</a>
    </div>
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">招聘 / 面试</p>
        <p>可以先看代表作，再补一篇日志和一篇文章，快速判断我在项目、复盘和表达上的完整度。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">合作沟通</p>
        <p>项目案例讲成果，日志讲过程，长文讲方法，能更完整地承接“你具体是怎么做事的”这个问题。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">同行交流</p>
        <p>如果你更关心系统设计、内容组织或原型收口方式，文章和日志会比单纯的作品截图更有信息量。</p>
      </div>
    </div>
  </section>
</BaseLayout>
