---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveFilter from '../../components/ArchiveFilter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DevlogCard from '../../components/DevlogCard.astro';
import { withBase } from '../../utils/site';
import { sortEditorialEntries } from '../../utils/entries';
import { devlogProjectLabels, formatDate, siteMeta } from '../../utils/site-meta';
import { getCollectionPageSchema } from '../../utils/schema';

const logs = sortEditorialEntries(await getCollection('devlogs'));
const featuredCount = logs.filter((log) => log.data.featured).length;
const projectCount = new Set(logs.map((log) => log.data.project)).size;
const latestLog = logs[0];
const entryLog = logs[0];
const filterProjects = Array.from(new Set(logs.map((log) => log.data.project))).map((project) => ({
  label: devlogProjectLabels[project] ?? project,
  value: project
}));
const pageDescription = '项目开发过程、阶段结论和关键方案取舍记录。';
const collectionSchema = getCollectionPageSchema({
  site: Astro.site,
  path: '/logs',
  name: `开发日志 | ${siteMeta.name}`,
  description: pageDescription,
  itemType: 'BlogPosting',
  items: logs.map((log) => ({
    name: log.data.title,
    url: `/logs/${log.id}`,
    description: log.data.description,
    image: log.data.coverImage
  }))
});
---

<BaseLayout title={`开发日志 | ${siteMeta.name}`} description={pageDescription} structuredData={collectionSchema}>
  <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '日志' }]} />
  <section class="page-heading card page-heading--rich">
    <p class="eyebrow">Devlogs</p>
    <h1>开发日志</h1>
    <p>这里不是流水账，而是把阶段目标、方案取舍和版本结论整理成外部也能读懂的项目过程记录。</p>
  </section>

  <section class="section-banner">
    <div class="feature-grid">
      <div class="mini-panel">
        <p class="eyebrow">日志总数</p>
        <strong>{logs.length}</strong>
        <p>用于持续追踪项目与站点演进。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">关联项目</p>
        <strong>{projectCount}</strong>
        <p>目前覆盖的项目与主题范围。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">精选日志</p>
        <strong>{featuredCount}</strong>
        <p>更适合第一次阅读的阶段节点。</p>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">最近更新</p>
        <strong>{latestLog ? formatDate(latestLog.data.pubDate) : '待补充'}</strong>
        <p>尽量让关键变化有清晰的阶段记录。</p>
      </div>
    </div>
  </section>

  {entryLog && (
    <section class="card">
      <div class="section-heading">
        <div>
          <h2>建议起点</h2>
          <p class="content-meta">如果你想先看“我是怎么推进项目的”，可以从当前最适合外部阅读的一篇阶段日志开始。</p>
        </div>
        <a href={withBase(`/logs/${entryLog.id}`)}>开始阅读</a>
      </div>
      <div class="mini-panel">
        <p class="eyebrow">当前推荐日志</p>
        <strong>{entryLog.data.title}</strong>
        <p>{entryLog.data.description}</p>
      </div>
    </section>
  )}

  <ArchiveFilter
    id="logs-archive"
    placeholder="搜索日志标题、描述、标签或项目"
    chips={filterProjects}
    emptyMessage="没有找到匹配的日志，可以换个项目或关键词继续筛选。"
  />

  <section class="grid grid--cards-lg" data-filter-target="logs-archive">
    {logs.map((log) => (
      <div
        class="filter-item-shell"
        data-filter-item
        data-search={`${log.data.title} ${log.data.description} ${log.data.tags.join(' ')} ${devlogProjectLabels[log.data.project] ?? log.data.project}`}
        data-groups={log.data.project}
      >
        <DevlogCard
          href={`/logs/${log.id}`}
          title={log.data.title}
          description={log.data.description}
          pubDate={log.data.pubDate}
          tags={log.data.tags}
          project={log.data.project}
          featured={log.data.featured}
        />
      </div>
    ))}
  </section>
</BaseLayout>
